{
	"id": "ironsworn-impacts",
	"title": "Ironsworn Impacts",
	"description": "Adds Ironsworn and Starforged Impacts to tokens",
	"authors": [
		{
			"name": "Matheus Clemente",
			"url": "https://github.com/mclemente",
			"discord": "mclemente"
		},
		{
			"name": "David Y. Hudson",
			"url": "https://github.com/jendave",
			"discord": "jendave"
		}
	],
	"esmodules": ["module/ironsworn-impacts.js"],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "lang/en.json"
		}
	],
	"packs": [
		{
		  "name": "ironswornimpactsentries",
		  "label": "Ironsworn Impacts Entries",
		  "path": "./packs/ironsworn-impacts-entries",
		  "type": "JournalEntry",
		  "system": "foundry-ironsworn"
		},
		{
		  "name": "ironswornimpactsmacros",
		  "label": "Ironsworn Impacts Macros",
		  "path": "./packs/ironsworn-impacts-macros",
		  "type": "Macro",
		  "system": "foundry-ironsworn"
		}
	  ],
	  "packFolders": [
		{
		  "name": "Ironsworn Impacts",
		  "packs": [
			"ironswornimpactsentries",
			"ironswornimpactsmacros"
		  ]
		}
	  ],
	"styles": ["styles/ironsworn-impacts.css"],
	"compatibility": {
		"minimum": "13",
		"verified": "13",
		"maximum": "14"
	},
	"relationships": {
		"systems": [
			{
			  "id": "foundry-ironsworn",
			  "type": "system",
			  "manifest": "https://github.com/ben/foundry-ironsworn/releases/latest/download/system.json",
			  "compatibility": {
				"minimum": "1.27.0",
				"verified": "1.27"
			  }
			}
		  ]
	},
	"version": "#{VERSION}#",
	"manifest": "#{MANIFEST}#",
	"url": "#{URL}#",
	"download": "#{DOWNLOAD}#",
	"license": "https://raw.githubusercontent.com/jendave/ironsworn-impacts/main/LICENSE",
	"readme": "https://raw.githubusercontent.com/jendave/ironsworn-impacts/main/README.md",
	"bugs": "https://github.com/jendave/ironsworn-impacts/issues",
	"changelog": "https://raw.githubusercontent.com/jendave/ironsworn-impacts/main/CHANGELOG.md"
}
